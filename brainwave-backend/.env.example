# 執行時會吃這些變數（Spring Boot 從環境變數讀取）
# 部署到 Zeabur 時，在服務 Variables 設定同名變數即可

# 必填：正式環境
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:mysql://host:3306/dbname?useUnicode=true&characterEncoding=utf8&useSSL=true&serverTimezone=Asia/Taipei
DB_USERNAME=
DB_PASSWORD=

# 選填（有預設）
# SERVER_PORT=8080
# JPA_DDL_AUTO=validate
# APP_AUTH_DEMO_USERNAME=demo
# APP_AUTH_DEMO_PASSWORD=demo
# APP_AUTH_FRONT_DEMO_USERNAME=demo
# APP_AUTH_FRONT_DEMO_PASSWORD=demo
